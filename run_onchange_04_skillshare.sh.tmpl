#!/bin/bash

# registry.yaml hash: {{ include "dot_config/skillshare/registry.yaml" | sha256sum }}

set -euo pipefail

SKILLS_DIR="$HOME/.local/share/agent-skills"
if [ ! -d "$SKILLS_DIR" ]; then
    echo "Cloning agent-skills..."
    git clone git@github.com:dstotijn/agent-skills.git "$SKILLS_DIR"
fi

echo "Installing and syncing skillshare skills..."
mise exec -- skillshare install
mise exec -- skillshare sync
